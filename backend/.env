# Server
PORT=5000
NODE_ENV=development

# Neon PostgreSQL
DATABASE_URL=postgresql://username:password@ep-xxxxx-pooler.aws.neon.tech/ubmarket

# JWT
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=7d

# Email (using Gmail or any SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Upload limits
MAX_FILE_SIZE=5242880
UPLOAD_PATH=uploads